    "@tsparticles/vue3": "^4.2.1",
    "axios": "1.6.8",
    "d3": "^7.9.0",
    "docx-preview": "^0.3.7",
    "echarts": "^6.1.0",
    "element-plus": "2.6.1",
    "grid-layout-plus": "^1.1.1",
    "gsap": "^3.15.0",
    "highlight.js": "^11.11.1",
    "jsencrypt": "^3.5.4",
    "lodash-es": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
