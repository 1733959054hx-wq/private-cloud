    "sockjs-client": "^1.6.1",
    "spark-md5": "^3.0.2",
    "vue": "3.4.21",
    "vue-router": "4.3.0",
    "vue3-lottie": "^3.3.1",
    "y-quill": "^1.0.0",
    "y-websocket": "^3.0.0",
