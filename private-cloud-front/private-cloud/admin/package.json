{
  "name": "private-cloud-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "18.19.1",
    "pnpm": "8.15.0"
  },
  "scripts": {
    "dev": "node --input-type=module -e \"import{rmSync}from'node:fs';rmSync('node_modules/.vite',{recursive:true,force:true})\" && vite",
    "dev:force": "vite --force",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "1.6.8",
    "echarts": "^6.1.0",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "2.6.1",
    "pinia": "2.1.7",
    "vue": "3.4.21",
    "vue-echarts": "^8.0.1",
    "vue-router": "4.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.0.0",
    "@typescript-eslint/parser": "7.0.0",
    "@vitejs/plugin-legacy": "5.2.0",
    "@vitejs/plugin-vue": "5.0.4",
    "eslint": "8.57.0",
    "eslint-plugin-vue": "9.23.0",
    "prettier": "3.2.5",
    "sass": "1.72.0",
    "typescript": "5.4.3",
    "unplugin-auto-import": "0.17.5",
    "unplugin-vue-components": "0.26.0",
    "vite": "5.2.8",
    "vue-tsc": "2.0.6"
  }
}
